# Copy to `.env` (gitignored). Never commit real secrets.

# From: pnpm exec wrangler d1 create sweepy
# Safe to keep here — local `pnpm dev` ignores it unless SWEEPY_DEPLOY=1
# (set automatically by `pnpm deploy`).
CLOUDFLARE_D1_DATABASE_ID=

# Runtime config (NUXT_ prefix). Validated in server/utils/env.ts.
# IANA timezone that seeds household settings on first boot (ADR 0008).
NUXT_HOUSEHOLD_TIMEZONE=America/Chicago

# Runtime secrets use the NUXT_ prefix and are validated in server/utils/env.ts
# (see its header for the full recipe). Example for later:
# NUXT_BETTER_AUTH_SECRET=
